# DeepSeek anahtarı yalnızca sunucuda kullanılır. NEXT_PUBLIC_ öneki eklemeyin.
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Kullanıcıya görünen cevabı yazan güçlü katman.
DEEPSEEK_MODEL=deepseek-v4-pro
# Arama planı ve semantik sıralama gibi dar şemalı yardımcı çağrıların katmanı.
# Sıralama kalitesi yetersiz gelirse buraya deepseek-v4-pro yazarak geri alın.
DEEPSEEK_MODEL_FAST=deepseek-v4-flash

# İsteğe bağlı gerçek embedding sıralaması. Tanımlanmazsa semantik sıralama
# mevcut DeepSeek bağlantısıyla yapılır.
# OPENAI_API_KEY=sk-...
# text-embedding-3-large daha isabetli ama 6,5 kat pahalıdır ($0,13/M).
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=https://api.openai.com/v1

# Uygulama erişimi
APP_PASSWORD=uzun-ve-benzersiz-bir-parola
# Üretmek için: openssl rand -hex 32
SESSION_SECRET=en-az-32-karakter-rastgele-bir-deger

# Paylaşılan durum (Vercel için önerilir). Tanımlanmazsa istek sınırları ve
# önbellek lambda örneği başına çalışır; bu da Bedesten kotasının aşılmasına
# yol açar. Upstash Redis entegrasyonu bu iki değişkeni otomatik ekler.
# UPSTASH_REDIS_REST_URL=https://....upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
# Bedesten'in ölçülen kotası 30 saniyede 10 istek; varsayılan 8/30sn.
# BEDESTEN_SHARED_LIMIT=8
# BEDESTEN_SHARED_WINDOW_S=30

# İsteğe bağlı güvenlik/kapasite ayarları
# TRUSTED_ORIGIN=https://ictihat.example.com
# COOKIE_SECURE=auto
# BEDESTEN_MIN_GAP_MS=3500
# Semantik sıralama için tam metni açılacak aday sayısı.
# SEMANTIC_CANDIDATES=10
# Asgari eleme puanı. Verilmezse sağlayıcının varsayılanı kullanılır:
# OpenAI embedding 0.28, DeepSeek puanlaması 0.42. İki ölçek farklı olduğu
# için buraya sabit bir değer yazmak sağlayıcı değişince yanıltır.
# SEMANTIC_MIN_SCORE=
# Varsayılanlar sırasıyla 6, 3 ve 120000'dir. Artırmak yanıtı yavaşlatır.
# MAX_RESEARCH_TURNS=6
# MAX_SOURCES=3
# MAX_EVIDENCE_CHARS=120000
# CACHE_DIR=/kalici/bir/dizin

# /api/health cron ucunu korumak için (Vercel Cron bu değeri Bearer olarak yollar)
# CRON_SECRET=openssl-ile-uretilmis-bir-deger
# MCP getir araçlarında sayfa başına karakter sayısı (varsayılan 25000)
# MCP_PAGE_CHARS=25000
