<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.chillandbuild.ictihat</string>

  <!-- ↓↓↓ BURAYI KENDİ KULLANICI ADINLA DEĞİŞTİR ↓↓↓ -->
  <key>ProgramArguments</key>
  <array>
    <string>/Users/KULLANICI/Projeler/ictihat-asistani/deploy/run.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/KULLANICI/Projeler/ictihat-asistani</string>
  <!-- ↑↑↑ İKİ YOLU DA DÜZELT ↑↑↑ -->

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/tmp/ictihat.out.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/ictihat.err.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PORT</key>
    <string>3000</string>
  </dict>
</dict>
</plist>
